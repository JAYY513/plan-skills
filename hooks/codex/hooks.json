{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "sh .agents/skills/plan-task/hooks/session-start.sh 2>/dev/null || true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .agents\\skills\\plan-task\\hooks\\session-start.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh .agents/skills/plan-task/hooks/pre-tool-use.sh 2>/dev/null || true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .agents\\skills\\plan-task\\hooks\\pre-tool-use.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh .agents/skills/plan-task/hooks/post-tool-use.sh 2>/dev/null || true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .agents\\skills\\plan-task\\hooks\\post-tool-use.ps1"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh .agents/skills/plan-task/hooks/pre-compact.sh 2>/dev/null || true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .agents\\skills\\plan-task\\hooks\\pre-compact.ps1"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh .agents/skills/plan-task/hooks/user-prompt-submit.sh 2>/dev/null || true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .agents\\skills\\plan-task\\hooks\\user-prompt-submit.ps1"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh .agents/skills/plan-task/hooks/permission-request.sh 2>/dev/null || true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .agents\\skills\\plan-task\\hooks\\permission-request.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh .agents/skills/plan-task/hooks/stop-gate.sh 2>/dev/null || true",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .agents\\skills\\plan-task\\hooks\\stop-gate.ps1"
          }
        ]
      }
    ]
  }
}
